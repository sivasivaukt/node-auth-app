{
  "name": "next-auth-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:app": "turbo run dev --filter=app",
    "dev:bo": "turbo run dev --filter=bo",
    "build:app": "turbo run build --filter=app",
    "build:bo": "turbo run build --filter=bo"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "npm@11.5.2",
  "engines": {
    "node": ">=20"
  }
}
